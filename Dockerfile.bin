FROM eclipse-temurin:17-jdk-alpine AS builder
WORKDIR /build

# Copy Maven wrapper + POM first (layer cache)
COPY backend/pom.xml ./pom.xml

# Download dependencies (offline-friendly cache layer)
RUN --mount=type=cache,target=/root/.m2 \
    mvn dependency:go-offline -q 2>/dev/null || true

# Copy source
COPY backend/src ./src

# Build fat JAR (skip tests for image build — run them separately)
RUN --mount=type=cache,target=/root/.m2 \
    mvn package -DskipTests -q

# ── Runtime image ─────────────────────────────────────────────────────────────
FROM eclipse-temurin:17-jre-alpine
WORKDIR /app

COPY --from=builder /build/target/service-booking-platform-1.0.0.jar app.jar

# The CLI reads from stdin; use -it when running interactively
ENTRYPOINT ["java", "-jar", "app.jar"]
